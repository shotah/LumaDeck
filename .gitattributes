# Normalize line endings across Windows + Linux contributors.
* text=auto eol=lf

*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.json  text eol=lf

# Binary assets (none today, but document the convention).
*.png   binary
*.jpg   binary
*.bin   binary
